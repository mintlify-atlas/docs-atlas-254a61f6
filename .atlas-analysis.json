  "keyFeatures": [
    "Complete 5G SA core with 9 network functions",
    "Docker-based containerized deployment",
    "Service-based architecture (SBA)",
    "UERANSIM integration for testing",
    "Web UI for subscriber management",
    "Multi-language implementation (Rust & TypeScript)",
    "MongoDB-backed data persistence",
    "Production-ready Docker Compose orchestration"
  ],
  "publicApiSurface": [
    "NRF - Network Repository Function (Service discovery)",
    "AMF - Access and Mobility Management (Registration, mobility)",
    "SMF - Session Management (PDU sessions)",
    "UPF - User Plane Function (Data forwarding)",
    "AUSF - Authentication Server (Subscriber authentication)",
    "UDM - Unified Data Management (Subscriber data)",
    "NSSF - Network Slice Selection (Slice selection)",
    "SCP - Service Communication Proxy (Inter-NF communication)",
    "SEPP - Security Edge Protection Proxy (Inter-PLMN security)",
    "Web UI API - Subscriber management endpoints"
  ]
